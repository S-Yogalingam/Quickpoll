# QuickPoll configuration (example). Copy to .env and adjust.
# All values have sane defaults for local development.

# Port the server listens on.
PORT=8090
HOST=0.0.0.0

# Flask session secret (change in production).
QUICKPOLL_SECRET_KEY=dev-secret-change-me

# MySQL connection.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=quickpoll
MYSQL_PASSWORD=quickpoll_pw
MYSQL_DB=quickpoll
